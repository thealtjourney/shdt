# SHDT Production Environment Variables
# Copy this file to .env and update with actual values

# ============================================================================
# Database Configuration
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=shdt_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/shdt_db

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your_random_secret_key_here_generate_with_python_secrets
LOG_LEVEL=INFO

# ============================================================================
# API Configuration
# ============================================================================
API_URL=https://yourdomain.com/api
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# Frontend Configuration
# ============================================================================
REACT_APP_API_URL=https://yourdomain.com/api
REACT_APP_ENV=production

# ============================================================================
# SSL/TLS Configuration
# ============================================================================
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
SSL_EMAIL=admin@yourdomain.com

# ============================================================================
# Backup Configuration
# ============================================================================
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FORMAT=json
LOG_OUTPUT=/app/logs

# ============================================================================
# Security Settings
# ============================================================================
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
SESSION_TIMEOUT=86400
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_REGISTRATION=true
ENABLE_API_DOCS=false
ENABLE_ADMIN_PANEL=true

# ============================================================================
# Data Import Settings
# ============================================================================
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_CSV_COLUMNS=unit_id,unit_name,address,city,state,zip,bed_count,bath_count,unit_type,status

# ============================================================================
# Email Configuration (Optional)
# ============================================================================
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# Monitoring and Health Checks
# ============================================================================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
ENABLE_METRICS=true

# ============================================================================
# Geographic/Geocoding Settings
# ============================================================================
GEOCODING_PROVIDER=nominatim  # or google, mapbox, etc.
GEOCODING_API_KEY=your_api_key_if_needed

# ============================================================================
# Performance Tuning
# ============================================================================
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
POSTGRES_MAX_CONNECTIONS=100
NGINX_WORKER_CONNECTIONS=1024

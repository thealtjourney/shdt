# ─────────────────────────────────────────────
# SHDT backend — example environment variables
# ─────────────────────────────────────────────
# Copy to `.env` and edit. Anything not set here falls through to safe
# defaults in code.

# ── Database ────────────────────────────────
DATABASE_URL=postgresql://shdt:shdt_dev_password@localhost:5432/shdt

# ── Server ──────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=False
APP_VERSION=0.1.0
GIT_COMMIT=unknown

# ── CORS ────────────────────────────────────
# Comma-separated list. In production, set to your real frontend domain(s).
CORS_ALLOW_ORIGINS=http://localhost:5173,https://localhost:5173

# Frontend URL — used in emails / unsubscribe links
FRONTEND_URL=http://localhost:5173

# ── Auth ────────────────────────────────────
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Email ───────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SENDER_EMAIL=noreply@example.com

# ── Data sources ────────────────────────────
DATA_SOURCE_PATH=/path/to/data/files
UPDATE_SCHEDULE_HOURS=24

# ── Logging ─────────────────────────────────
LOG_LEVEL=INFO
DEPLOY_ENV=local                 # local | ci | staging | prod

# ── Secrets backend (NEW) ───────────────────
# dotenv  — read .env then process env (default for local dev)
# env     — read process env only (typical for containers / CI)
# keyvault — Azure Key Vault (requires AZURE_KEY_VAULT_URL)
SECRETS_BACKEND=dotenv
# AZURE_KEY_VAULT_URL=https://my-vault.vault.azure.net/

# ── Storage backend (NEW) ───────────────────
# local      — store files on the local filesystem
# azure_blob — store files in Azure Blob Storage
STORAGE_BACKEND=local
# STORAGE_LOCAL_DIR=/path/to/local/storage  (defaults to server/storage_data)

# Azure Blob (only used when STORAGE_BACKEND=azure_blob)
# AZURE_STORAGE_ACCOUNT=mystorageaccount
# AZURE_STORAGE_CONTAINER=shdt-files
# AZURE_STORAGE_CONNECTION_STRING=...

# ── Test database (CI / local) ──────────────
# TEST_DATABASE_URL=postgresql://shdt:shdt_dev_password@localhost:5432/shdt_test
